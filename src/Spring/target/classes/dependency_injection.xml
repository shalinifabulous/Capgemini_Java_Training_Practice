<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
http://www.springframework.org/schema/beans
http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean id = "L1" class = "dependency_injection.Library">
            <property name = "id" value = "101"></property>
            <property name = "name" value="Friends"></property>
            <property name = "book" ref = "B1"></property>
    </bean>

    <bean id = "B1" class = "dependency_injection.Book">
        <property name ="bookId" value="1"></property>
        <property name="bookName" value="Wings of Fire"></property>
    </bean>
</beans>